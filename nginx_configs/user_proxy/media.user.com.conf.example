# 用户自定义共享线路单域名样板
# 入口域名示例：media.user.com
# 这台反代服务器不直接对接 Plex / Emby 官方入口，
# 而是根据官方入口附带的 X-PMS-Entry-Host 分流到受保护的 origin 域名。

map $http_x_pms_entry_host $media_origin_host {
    default emby-origin.misaya.org;
    plex.misaya.org plex-origin.misaya.org;
    emby.misaya.org emby-origin.misaya.org;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

server {
    listen 80;
    listen [::]:80;
    server_name media.user.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name media.user.com;

    ssl_certificate     /etc/letsencrypt/live/media.user.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/media.user.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass https://$media_origin_host;
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_redirect off;

        proxy_ssl_server_name on;
        proxy_set_header Host $media_origin_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $http_x_pms_entry_host;
        proxy_set_header X-PMS-Entry-Host $http_x_pms_entry_host;
        proxy_set_header X-PMS-Route-Service $http_x_pms_route_service;
        proxy_set_header X-PMS-Route-Timestamp $http_x_pms_route_timestamp;
        proxy_set_header X-PMS-Route-Signature $http_x_pms_route_signature;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        client_max_body_size 0;
        proxy_connect_timeout 60s;
        proxy_read_timeout 36000s;
        proxy_send_timeout 36000s;
    }
}
